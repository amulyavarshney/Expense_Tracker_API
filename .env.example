# dev | prod — selects settings when DJANGO_SETTINGS_MODULE=expense_tracker.settings
ENV=dev
# Or set explicitly: expense_tracker.settings.dev | expense_tracker.settings.prod
# DJANGO_SETTINGS_MODULE=expense_tracker.settings.dev

SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: PostgreSQL connection (omit to use SQLite)
# DATABASE_URL=postgresql://expense_user:expense_pass@db:5432/expense_tracker

# CORS (comma-separated). Defaults in settings already include localhost + GitHub Pages.
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,https://amulyavarshney.github.io
